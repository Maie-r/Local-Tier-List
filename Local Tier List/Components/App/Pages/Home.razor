@page "/"
@using System.Text.Json
@using Local_Tier_List.Components.App.Modals
@using Microsoft.Extensions.Logging
@using Microsoft.Maui.ApplicationModel
@using System.Diagnostics
@using MaieBlazorLib
@inject ILogger<Home> Logger
@inject IJSRuntime JS
@inject ISnackbar Snackbar
<link href="css/TierListStyling.css" rel="stylesheet" />

<div class="m-md-1 p-md-1 m-lg-4 p-lg-4 overflow-hidden smoothScaling">
	<h1 class="d-flex text-light mx-auto justify-content-center" style="font-weight: 600">Local Tier List Maker</h1>
	<div class="row col-12 d-flex flex-column text-light m-2">
		<h3 style="font-weight: 500"> Tier Lists: </h3>
		@if (!mobile){
				<button class="m-2 ms-4 col-1 bg-highlight clickableOuter rounded p-1" @onclick="() => OpenDataFolder()">
				<MudIcon Icon="@Icons.Material.Filled.Folder" Title="Data Folder"/>
				</button>
		}
		<div class="form-check form-switch ms-4">
			<input class="form-check-input" type="checkbox" id="editform" checked="@editTierlists"
				   @onchange="() => editTierlists = !editTierlists">
			<label class="form-check-label" for="editform">
				Edit Mode
			</label>
		</div>
		<TLList Folder="rootfolder"
				editMode="editTierlists"
				mobile="mobile"
				IsRoot="true"
				OnSelect="Select"
				OnNewTierList="() => showcase = false"
				OnChangesMade="Save"
				OnDeletedItems="(e) => { if (e.Any((e) => e == selected)) selected = null; }"
				OnFolderOpened="(e) => CurrentFolder = e"
		>
		</TLList>
		<div class="d-flex mx-2 my-2 col-12 col-md-4"> <!-- IMPORT EXPORT MERGE BUTTONS -->
			<div class="row col-sm-6 col-md-2 col-lg-1 mx-2 my-1 d-flex flex-fill flex-wrap">
				<div class="row p-0 col-12 d-flex flex-fill">
					<div class="d-flex col-12 p-0 flex-nowrap flex-fill flex-row">
						<h5 class="clickableOuter flex-fill p-1 m-0 text-center rounded btn bg-primary align-content-center text-light" @onclick="@(() => OpenModal(IOModalType.Import))"> <MudIcon Icon="@Icons.Material.Filled.Download" Title="Import" /> Import Tierlists </h5>
					</div>
				</div>
			</div>
			<div class="row col-sm-6 col-md-2 col-lg-1 mx-2 my-1 d-flex flex-fill flex-wrap">
				<div class="row p-0 col-12 d-flex flex-fill">
					<div class="d-flex col-12 p-0 flex-nowrap flex-fill flex-row">
						<h5 class="clickableOuter flex-fill p-2 m-0 text-center rounded btn bg-primary align-content-center text-light" @onclick="() => OpenModal(IOModalType.Export)"> <MudIcon Icon="@Icons.Material.Filled.Upload" Title="Export" /> Export All Tierlists </h5>
					</div>
				</div>
			</div>
			<!-- Removed to add to the Tierlist component instead
			<div class="row col-sm-6 col-md-2 col-lg-1 mx-2 my-1 d-flex flex-fill flex-wrap">
				<div class="row p-0 col-12 d-flex flex-fill">
					<div class="d-flex col-12 p-0 flex-nowrap flex-fill flex-row">
						<h5 class="clickableOuter flex-fill p-2 m-0 text-center rounded btn bg-primary align-content-center text-light" @onclick="@(() => OpenModal(IOModalType.Merge))"> MERGE TWO (DEBUG) </h5>
					</div>
				</div>
			</div>-->
		</div>
	</div>
	@if (selected != null)
	{
		<h5 class="ms-4">Display Settings:</h5>
		<div class="d-flex flex-row gap-3 p-2 darken-25 rounded">
			<div class="form-check form-switch">
				<input class="form-check-input" type="checkbox" id="showcaseform" checked="@showcase"
					   @onchange="() => Toggle(ref showcase)">
				<label class="form-check-label" for="showcaseform">
					Showcase Mode
				</label>
			</div>

			<div class="form-check form-switch">
				<input class="form-check-input" type="checkbox" id="minimalform"
					   @onchange="() => Toggle(ref minimal)">
				<label class="form-check-label" for="minimalform">
					Minimal Mode
				</label>
			</div>

			<div class="form-check form-switch">
				<input class="form-check-input" type="checkbox" id="textform"
					   @onchange="() => Toggle(ref NoImg)">
				<label class="form-check-label" for="textform">
					Text Only
				</label>
			</div>
		</div>

		<TierListComp selected="selected" tl="TierService.tl" showcase="showcase" minimal="minimal" NoImg="NoImg"
		OnExport="@(() => SnackAlert("Exported Tierlist copied to clipboard"))" 
		OnError="@((e) => SnackError(e))"
		OnLoaded="@(async (e) => await UILoaded(e))" OnLoadingStart="@(async (e) => await UILoading(e))"
		OnSave="@(async () => await Save())"
		OnItemCopied="@(() => SnackAlert("Item copied!"))"
		/>
	}

	<!-- -- -- -- -- -- -- MODALS -- -- -- -- -- -- -- 
	@if (Loading)
	{
		<LoadingDisplay/>
	}
-->
	@if (CurrentModal != IOModalType.None)
	{
		<IOModals ModalType="CurrentModal"
				  CurrentFolder="CurrentFolder"
				  OnClose="() => OpenModal(IOModalType.None)"
				  OnChangesMade="Save"
				  OnSnackAlert="SnackAlert"
				  OnSnackError="SnackError"
				  OnSelected="Select"
		>
		</IOModals>
	}
</div>

@if (Loading)
{
	<div class="d-none">
		<MudColorPicker Label="eh" @bind-Text="preload" Placeholder="Select Color" />
	</div>
}


@code
{
	TLFolder rootfolder;
	TLFolder CurrentFolder;
	TierList? selected;

	bool mobile, minimal, NoImg, editTierlists;
	bool showcase = true;

	IOModalType CurrentModal = IOModalType.None;

	bool Loading = true;
	string LoadingMessage = "Loading...";

	CancellationTokenSource? _saveCts;

	// -------- GENERAL FUNCTIONS
	protected override async Task OnInitializedAsync()
	{
		mobile = OperatingSystem.IsAndroid() || OperatingSystem.IsIOS();
		rootfolder = TierService.RootFolder;
		CurrentFolder = rootfolder;
		if (rootfolder.Folders.Count <= 0 && rootfolder.Tierlists.Count <= 0)
			editTierlists = true;

	}

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (firstRender) await UILoaded();
	}

	void OpenDataFolder()
	{
		Process.Start("explorer.exe", TierService.GetMainFolder());
	}

	async Task Save()
	{
		_saveCts?.Cancel();
		_saveCts = new CancellationTokenSource();
		var token = _saveCts.Token;

		try
		{
			await Task.Delay(500, token);
			await TierService.SaveAll();
			Logger.LogInformation("Saving!");
		}
		catch (OperationCanceledException) { /* debounced away, that's fine */ }
	}

	// -------- TIERLIST MANAGEMENT
	async Task Select(TierList l)
	{
		if (l == selected)
		{
			selected = null;
		}
		else
		{
			await UILoading("Loading Tierlist...");
			selected = l;
		}
	}

	async Task AddSelect(TierList l)
	{
		if (!TierService.TierLists.Contains(l)){
			CurrentFolder.Tierlists.Add(l);
			TierService.TierLists.Add(l);
		}
		await Select(l);
	}

	// -------- MODAL HANDLING
	async Task OpenModal(IOModalType type)
	{
		CurrentModal = type;
	}
	void Toggle(ref bool t)
	{
		t = !t;
		StateHasChanged();
	}

	// -------- LOADING HANDLING
	async Task UILoaded()
	{
		await UILoaded("");
	}

	async Task UILoading()
	{
		await UILoading("Loading...");
	}

	async Task UILoaded(string? message)
	{
		Logger.LogInformation(message);
		Loading = false;
		LoadingMessage = "";
		StateHasChanged();
	}

	async Task UILoading(string? message)
	{
		Loading = true;
		LoadingMessage = message;
		StateHasChanged();
	}

	// -------- SNACK MESSAGES
	void SnackAlert(string message)
	{
		Snackbar.Add(message, Severity.Info);
	}
	void SnackError(string message)
	{
		Snackbar.Add(message, Severity.Error);
	}



	string preload;
}