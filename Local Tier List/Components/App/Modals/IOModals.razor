@using Local_Tier_List.Data.App
@using Microsoft.Extensions.Logging
@inject ILogger<IOModals> Logger
@inject IJSRuntime JS

@if (false)
{
	<LoadingDisplay />
}
else
{
	@switch (ModalType)
	{
		case IOModalType.Import:
			{
				<div class="maiedal d-flex flex-column text-center justify-content-center">
					<div class="p-4 darken-85 bgblur-5 d-flex text-center flex-column justify-content-center mx-auto text-light col-12 shadow col-md-6" style="border-radius: 2vw">
						<p> Paste below the JSON string of the Tierlist(s) you want to import! </p>
						<textarea class="font-monospace bg-dark text-light col-12 mb-2" style="height:200px;" @bind="importString"></textarea>
						<div>
							<p class="text-danger">@importErr</p>
						</div>
						<div class="form-check form-switch text-start mx-3 mb-3">
							<input class="form-check-input" type="checkbox" id="ireplace"
								   @onchange="() => ImportReplace = !ImportReplace">
							<label class="form-check-label" for="ireplace">
								Replace current Tierlists
							</label>
						</div>
						<div class="d-flex flex-row flex-wrap mx-auto">
							<button class="mx-2 border-1 border-white text-light rounded btn p-2" @onclick="OnClose">Cancel</button>
							<button class="mx-2 bg-highlight rounded btn p-2 text-light" @onclick="TryImport">Import</button>
						</div>
					</div>
				</div>
			}
			break;
		case IOModalType.Export:
			{
				<div class="maiedal d-flex flex-column text-center justify-content-center">
					<div class="p-4 darken-85 bgblur-5 d-flex text-center flex-column justify-content-center mx-auto text-light col-12 shadow col-md-6" style="border-radius: 2vw">
						<p> Which Tierlists do you want to export? </p>
						<div class="d-flex flex-column flex-wrap mx-auto justify-content-center">
							<button class="mx-2 my-1 bg-highlight rounded btn p-2 text-light" @onclick="ExportCurrentFolder">Export Tierlists from the Open Folder</button>
							<button class="mx-2 my-1 bg-highlight rounded btn p-2 text-light" @onclick="ExportAll">Export All Tierlists</button>
							<button class="mx-2 my-1 border-1 border-white text-light rounded btn p-2" @onclick="OnClose">Cancel</button>
						</div>
					</div>
				</div>
			}
			break;
	}
}

@code {
	[Parameter]
	public required IOModalType ModalType { get; set; }
	[Parameter]
	public required TLFolder CurrentFolder { get; set; }
	[Parameter]
	public EventCallback OnChangesMade { get; set; }
	[Parameter]
	public EventCallback OnClose { get; set; }
	[Parameter]
	public EventCallback<string?> OnSnackAlert { get; set; }
	[Parameter]
	public EventCallback<string?> OnSnackError { get; set; }
	[Parameter]
	public EventCallback<TierList> OnSelected { get; set; }

	// importing
	string importString = "";
	string importErr = "";
	bool ImportReplace = false;

	bool Loading = true;

	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (!firstRender)
			return;

		if (ModalType is IOModalType.Export && TierService.RootFolder.Folders.Count <= 0)
		{
			await ExportAll();
			await OnClose.InvokeAsync();
			return;
		}

		Loading = false;
		StateHasChanged();
	}

	async Task TryImport()
	{
		if (!String.IsNullOrEmpty(importString))
		{
			try
			{
				var imported = TierService.Import(importString);
				if (imported != null && imported.Count > 0)
				{
					if (ImportReplace)
					{
						TierService.TierLists.RemoveAll(e => CurrentFolder.Tierlists.Any((f) => e.Id == f.Id));
						CurrentFolder.Tierlists.Clear();
					}
					var Ids = TierService.TierLists.Select(e => e.Id).ToHashSet();
					foreach (var tl in imported)
					{
						if (Ids.Contains(tl.Id))
						{
							// I guess I could add a merge here but for now I'll just re-do the ID
							tl.Id = Guid.NewGuid();
						}
						TierService.TierLists.Add(tl);
						CurrentFolder.Tierlists.Add(tl);
					}
					if (imported.Count == 1 || ImportReplace)
						await OnSelected.InvokeAsync(imported[0]);
					//lists = TierService.TierLists;
					importErr = "";
					await OnClose.InvokeAsync();
					await OnChangesMade.InvokeAsync();
					
				}
				else
				{
					importErr = "Couldn't identify any elements in the json...";
				}
			}
			catch (Exception e)
			{
				importErr = e.Message;
			}
		}
	}

	async Task ExportCurrentFolder()
	{
		var used = CurrentFolder.Tierlists;
		await Export(used);
	}
	async Task ExportAll()
	{
		var used = TierService.TierLists;
		await Export(used);
	}

	async Task Export(List<TierList> tierlists)
	{
		var json = TierService.tl?.ExportJson() ?? string.Empty;
		json = TierListSaveData.ExportTierList(tierlists);
		if (string.IsNullOrEmpty(json))
		{
			Logger.LogWarning("ExportAll: no JSON produced from TierService.tl.ExportJson()");
			await OnSnackError.InvokeAsync("No TierLists to export.");
			return;
		}

		try
		{
#if ANDROID || WINDOWS || IOS || MACCATALYST
			// Use native MAUI clipboard when running as a MAUI app (Android, Windows, iOS, MacCatalyst).
			await Clipboard.SetTextAsync(json);
#else
			// Fallback for browser/web: use navigator.clipboard via JS interop.
			await JS.InvokeVoidAsync("navigator.clipboard.writeText", json);
#endif
			Logger.LogInformation("Exported JSON copied to clipboard.");
			await OnSnackAlert.InvokeAsync("TierLists Data copied to clipboard.");
		}
		catch (Exception ex)
		{
			Logger.LogError(ex, "Failed to copy exported JSON to clipboard using primary method.");
			// Try the other approach as a best-effort fallback.
			try
			{
				await JS.InvokeVoidAsync("navigator.clipboard.writeText", json);
				Logger.LogInformation("Fallback: exported JSON copied to clipboard via JS.");
				await OnSnackAlert.InvokeAsync("TierLists Data copied to clipboard.");
			}
			catch (Exception jsEx)
			{
				Logger.LogError(jsEx, "Fallback copy to clipboard via JS also failed.");
				await OnSnackError.InvokeAsync("Failed to copy TierLists Data to clipboard.");
			}
		}
		await OnClose.InvokeAsync();
	}
}

